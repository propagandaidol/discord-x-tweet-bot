# Discord Bot設定
DISCORD_BOT_TOKEN=your_discord_bot_token_here
# 投稿先チャンネルID。複数指定する場合はカンマ区切り (例: 123456789012345678,987654321098765432)
DISCORD_CHANNEL_ID=123456789012345678

# 監視対象のXアカウント (@は不要、スクリーンネームのみ)
TARGET_X_USERNAME=example_user

# Xログイン用アカウント (botの投稿取得専用アカウントの使用を推奨。メインアカウントは使わないこと)
X_USERNAME=your_x_username
X_EMAIL=your_x_email
X_PASSWORD=your_x_password

# ポーリング間隔(秒)。頻繁すぎるとアカウント制限のリスクが上がるため300秒(5分)以上を推奨
POLL_INTERVAL_SECONDS=300
